"""memory consolidation

Hypothesis: Evaluate whether memory consolidation improves final product output without paid dependency.
Category: 8.43 Memory and Negative Learning
Expected runtime use: candidate_or_supporting_governance
"""

from __future__ import annotations

from typing import Any

from src.rag.schemas import RetrievedContext


class MemoryConsolidation:
    """memory consolidation"""

    def __init__(self, config: Any | None = None) -> None:
        self.config = config or {}

    def run(self, contexts: list[RetrievedContext], **kwargs: Any) -> list[RetrievedContext]:
        return self._apply(contexts, **kwargs)

    def _apply(self, contexts: list[RetrievedContext], **kwargs: Any) -> list[RetrievedContext]:
        if not getattr(self, "_short_term", None):
                    self._short_term: list[str] = []
                    self._long_term: dict[str, int] = {}
                for ctx in contexts:
                    self._short_term.append(ctx.chunk_id)
                    self._long_term[ctx.chunk_id] = self._long_term.get(ctx.chunk_id, 0) + 1
                if len(self._short_term) > 100:
                    for cid in set(self._short_term):
                        if self._long_term.get(cid, 0) >= 3:
                            for ctx in contexts:
                                if ctx.chunk_id == cid:
                                    ctx.relevance_score = min(1.0, ctx.relevance_score + 0.08)
                    self._short_term = self._short_term[-50:]
        return contexts
