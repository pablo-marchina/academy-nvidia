from __future__ import annotations

from typing import Any

from src.rag.schemas import RetrievedContext


class KnownRetrievalFailurePatterns:
    """known retrieval failure patterns"""

    def __init__(self, config: Any | None = None) -> None:
        self.config = config or {}

    def run(self, contexts: list[RetrievedContext], **kwargs: Any) -> list[RetrievedContext]:
        return self._apply(contexts, **kwargs)

    def _apply(self, contexts: list[RetrievedContext], **kwargs: Any) -> list[RetrievedContext]:
        failure_signals = ["no results", "no relevant", "no information",
                                   "not found", "unable to retrieve", "empty result"]
                for ctx in contexts:
                    match_count = sum(1 for s in failure_signals if s in ctx.content.lower())
                    if match_count:
                        ctx.relevance_score = max(0.0, ctx.relevance_score - match_count * 0.15)
        return contexts
