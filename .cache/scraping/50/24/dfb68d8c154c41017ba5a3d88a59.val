<div id="modalNewsletter" class="modal modalnewsletter-content modal-poup-up poup-up-addunit" classSelected="poup-up-addunit" duration="60" type_duration="m" style="height:unset !important;">
    <a href="#close-modal" rel="modal:close" class="close-modal">Close</a>
            <div class="content-poup-up-adunit">
            <div id="poup-up_mobile" class="poup-up-adunit-mobile">
            </div>
            <div id="poup-up_desktop" class="poup-up-adunit-desktop">
            </div>
        </div>
    </div><div class="content-poup-up-videos" id="popup-videos" data-is-single="">
    <div class="close" id="close-popup-videos">
        <span>Fechar</span>
    </div>
    <div class="contents">
        <div id="poup-up-video-desktop"></div>
        <div id="poup-up-video-mobile"></div>
        <div class="content-custom-video" data-video-source="dailymotion">
                            <div id="dm-player-script"></div>
                <script>
                    (function() {
                        var script = document.createElement('script');
                        script.src = 'https://geo.dailymotion.com/player/x1kmy6.js';
                        script.onload = function() {
                            dailymotion.createPlayer('dm-player-script', {
                                video: 'xajb0by',
                                params: {
                                    autoplay: true,
                                    mute: true,
                                    width: '100%',
                                    height: '100%'
                                }
                            }).then(function(player) {
                                player.setMute(true); 
                            });
                        };
                        document.head.appendChild(script);
                    })();
                </script>

                    </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        const popup = document.getElementById('popup-videos');
        const desktop = document.getElementById('poup-up-video-desktop');
        const mobile = document.getElementById('poup-up-video-mobile');
        const closeBtn = document.getElementById('close-popup-videos');
        const is_single = popup.dataset.isSingle;

        let canShow = false;
        let contentReady = false;

        function tryShowPopup() {
            if (canShow && contentReady) {
                popup.style.display = 'block';
            }
        }

        const mutationObs = new MutationObserver(function () {
            const hasContent =
                desktop.innerHTML.trim() !== '' ||
                mobile.innerHTML.trim() !== '' ||
                document.getElementById('dm-player-script') ||
                document.querySelector('.content-custom-video iframe');

            if (hasContent) {
                contentReady = true;
                mutationObs.disconnect();
                tryShowPopup();
            }
        });

        mutationObs.observe(desktop, { childList: true, subtree: true });
        mutationObs.observe(mobile, { childList: true, subtree: true });

        const alreadyHasContent =
            desktop.innerHTML.trim() !== '' ||
            mobile.innerHTML.trim() !== '' ||
            document.getElementById('dm-player-script') ||
            document.querySelector('.content-custom-video iframe');

        if (alreadyHasContent) {
            contentReady = true;
            mutationObs.disconnect();
        }

        function stopVideo() {
            const customVideo = document.querySelector('.content-custom-video');
            const videoSource = customVideo?.dataset.videoSource;

            if (videoSource === 'youtube') {
                const iframe = customVideo.querySelector('iframe');
                if (iframe) {
                    iframe.src = iframe.src.replace('autoplay=1', 'autoplay=0');
                }
            } else if (videoSource === 'dailymotion') {
                const script = document.getElementById('dm-player-script');
                if (script) script.remove();

                const dmPlayers = customVideo.querySelectorAll('[id^="dm-"], iframe[src*="dailymotion"]');
                dmPlayers.forEach(el => el.remove());
            }
        }

        closeBtn.addEventListener('click', function () {
            stopVideo();
            popup.style.display = 'none';
        });

        canShow = true;
        tryShowPopup();
    });
</script>
