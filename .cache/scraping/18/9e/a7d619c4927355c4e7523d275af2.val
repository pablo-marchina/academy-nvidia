.02em;--framer-text-color:var(--extracted-r6o4lv, var(--variable-reference-gyy8E4iDq-mtyoSvizw))">Our Felllowship Program</p></div></div><div class="framer-1mtjltk-container" data-framer-name="Icon Static" name="Icon Static"><!--$--><div style="display:contents"></div><!--/$--></div></div></a><!--/$--></div></div><!--/$--></div><div class="framer-112932o-container"><!--$--><div class="ssr-variant"><div style="width:100%;height:100%;position:relative"><div data-us-dpi="1.5" data-us-scale="1" data-us-fps="60" data-us-alttext data-us-arialabel style="width:100%;height:100%"></div></div></div><!--/$--></div><div class="framer-19t1vz0"><div class="framer-13bqneo"></div></div></div><div class="framer-wxhghz-container"><!--$--><div class="ecx-root" style="width:100%;position:relative;height:220vh;background:rgb(11, 32, 37);color:rgb(255, 255, 255)"><style>
.ecx-root * { box-sizing: border-box; }
.ecx-sticky { position: sticky; position: -webkit-sticky; top: 0; height: 100vh; display: flex; }

.ecx-panel {
    width: 52%; height: 100%; background: rgb(11, 32, 37);
    display: flex; flex-direction: column;
    padding: clamp(80px,11vh,108px) clamp(28px,2.6vw,48px) clamp(22px,3vh,38px) clamp(34px,4.6vw,84px);
    position: relative; z-index: 1; overflow: hidden;
}

.ecx-upper { position: relative; flex: 1 1 auto; min-height: 0; overflow: hidden; }
.ecx-state { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; }

.ec-headline { margin: 0 0 clamp(20px,2.6vh,32px) 0; line-height: 1.03; letter-spacing: -0.01em; font-weight: 500; }
.ec-sub { margin: clamp(16px,2.4vh,30px) 0 clamp(10px,1.3vh,16px) 0; line-height: 1.15; letter-spacing: -0.015em; max-width: 38em; }
.ec-sub.first { margin-top: 0; }
.ec-li { margin: 0 0 clamp(7px,0.9vh,11px) 0; line-height: 1.4; max-width: 38em; }
.ec-li:last-child { margin-bottom: 0; }

.ecx-bottom { flex: 0 0 auto; }
/* labels size to their own content; the explicit break (labelLines) + nowrap
   give exactly two lines; flex-wrap drops the right label BELOW the left one
   when the panel is too narrow, instead of colliding */
.ecx-tabs { display: flex; flex-wrap: wrap; gap: clamp(18px,2.4vh,30px) clamp(28px,4.6vw,96px); align-items: flex-start; }
.ecx-tab {
    appearance: none; -webkit-appearance: none; background: none; border: 0; margin: 0; padding: 2px 0;
    cursor: pointer; text-align: left; position: relative; color: inherit; transition: transform .25s ease;
    flex: 0 0 auto;
}
.ecx-tab span { display: block; white-space: nowrap; line-height: 1.05; letter-spacing: -0.01em; transition: color 0.4s ease; }
.ecx-tab:hover { transform: translateY(-2px); }
.ecx-tab:focus-visible { outline: 2px solid currentColor; outline-offset: 6px; border-radius: 4px; }

.ecx-meter { margin-top: clamp(12px,1.6vh,20px); width: 100%; height: 2px; background: rgba(255,255,255,0.10); border-radius: 2px; overflow: hidden; }
.ecx-meter-fill { width: 100%; height: 100%; }

.ecx-media { width: 48%; height: 100%; position: relative; overflow: hidden; }
.ecx-img { position: absolute; inset: 0; transition: opacity 0.45s ease; }
.ecx-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

@media (max-width: 860px) {
    /* SAME pinned + scroll-switched behavior as desktop — only the layout stacks.
       .ecx-root stays tall (pin range), .ecx-sticky stays sticky, .ecx-upper keeps
       its centred + clipped content so it never collides with the labels. */
    .ecx-sticky { flex-direction: column; }
    .ecx-media { width: 100%; height: 28vh; order: -1; flex: 0 0 auto; }
    .ecx-panel { width: 100%; flex: 1 1 auto; min-height: 0; padding: clamp(22px,3vh,36px) clamp(20px,6vw,40px) clamp(18px,2.6vh,30px); }
    .ecx-tabs { gap: clamp(16px,4vw,28px) clamp(28px,7vw,52px); }
}
@media (prefers-reduced-motion: reduce) { .ecx-tab { transition: none; } }
