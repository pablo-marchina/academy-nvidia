window.onload = () => {
  setTimeout(() => {
    const links = document.getElementsByTagName("link");
    for (const i of links) {
      if (i.getAttribute("rel") === 'canonical') {
        i.href = window.location.href;
        break;
      }
    }
  }, 1000);
}
