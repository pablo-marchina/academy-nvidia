    fill: #333;
}
.header__login__label{
  color: #333;
}
.menu-item-link {
      text-transform: none;
}
@media (min-width: 661px) {
         .header--root{
             height: 124px;
          }
         .header--root-size {
              height: 124px;
          }
         .header--internal-root-size{
               height: 97px;
         }
        .header[data-tenant="valor"] .header__brand__sublink {
               font-family: coranto, sans-serif;
	       font-size: 30px;
	}
        .header[data-tenant="valor"] .header__brand__sublink--sm {
              font-size: 19px;
              line-height: 20px;
              letter-spacing: -.5px;
              height: 42px;
        }
}

@media screen and (max-width: 768px){

    .header .container-actions {
             position:relative;
    }
    .header[data-tenant='valor'] .header__subscribe-btn {
            position: absolute;
            margin-left: 0;
            width: 100px;
    }

}

.navigation .menu-item-arrow, .navigation .menu-item.is-father>.menu-item-link .menu-item-arrow {
    top: 4px;
    margin-top: 0;
    background-color: #ddd;
    background-repeat: no-repeat;
    background-position: 50%;
    width: 32px;
    height: 32px;
}
.menu-item-arrow {
    background-image: url(data:image/svg+xml;charset=utf8,%3Csvg%20fill%3D%22%23006269%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20width%3D%2224%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M8.59%2016.34l4.58-4.59-4.58-4.59L10%205.75l6%206-6%206z%22%2F%3E%3Cpath%20d%3D%22M0-.25h24v24H0z%22%20fill%3D%22none%22%2F%3E%3C%2Fsvg%3E);
}
.menu-item.is-father>.menu-item-link .menu-item-arrow {
    right: 29px;
}
.menu-btn-back__icon {
    background-image: url(data:image/svg+xml;charset=utf8,%3Csvg%20fill%3D%22%23006269%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20width%3D%2224%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M15.41%2016.09l-4.58-4.59%204.58-4.59L14%205.5l-6%206%206%206z%22%2F%3E%3Cpath%20d%3D%22M0-.5h24v24H0z%22%20fill%3D%22none%22%2F%3E%3C%2Fsvg%3E);
}
.menu-product-color {
    color: #006269 !important;
}
.menu-submenu-title {
      text-transform: none;
}

@media screen and (max-width: 1024px) {

  .header--fixed:not(.header--internal) { transform: translateY(0);  }
  .header--fixed:not(.header--internal) .header__content {  transform: translateY(0); }
}
