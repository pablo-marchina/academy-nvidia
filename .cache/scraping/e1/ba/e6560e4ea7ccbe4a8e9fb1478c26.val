o\",\"slug\":\"frio\"},{\"term_id\":543366,\"name\":\"companhias-aereas\",\"slug\":\"companhias-aereas\"},{\"term_id\":453724,\"name\":\"Aviões\",\"slug\":\"avioes\"}],\"columnists_data\":false,\"exm_authors\":[{\"id\":650719610,\"name\":\"Vanessa Loiola\",\"slug\":\"vanessa-loiola\",\"posts_count\":1847,\"avatar\":\"https://classic.exame.com/wp-content/uploads/2025/06/vanessa_loiola.jpg\",\"role\":\"Redatora \",\"bio\":\"Jornalista freelancer formada pela PUC-SP. Passou pela Record, CNN Brasil, Suno Notícias, BM\u0026C News e RedeTV!.\",\"socials\":[],\"author_type\":\"wp\",\"wp_user\":{\"id\":185417090,\"slug\":\"vanessa-loiola\",\"name\":\"Vanessa Loiola\"},\"url_authorship\":\"\",\"hide_author_info\":false}],\"content_type\":null,\"featured_media_url\":\"https://classic.exame.com/wp-content/uploads/2026/06/woman-looking-out-plane-window-with-sun-shining-her-face.jpg\",\"sponsor_type\":\"none\",\"sponsor_name\":null,\"sponsor_campaign\":null,\"sponsor_link\":null},{\"id\":5776243,\"type\":\"post\",\"title\":{\"rendered\":\"O que a maconha faz no cérebro de um adolescente? Estudo faz alerta para os riscos\"},\"titulo_resumido_chamadas\":\"\",\"excerpt\":{\"rendered\":\"Pesquisa com mais de 463 mil adolescentes encontrou maior incidência de psicose, transtorno bipolar, depressão e ansiedade entre usuários de cannabis\"},\"date\":\"2026-06-29 19:09:57\",\"date_modified\":\"2026-06-29 19:09:57\",\"slug\":\"o-que-a-maconha-faz-no-cerebro-de-um-adolescente-estudo-faz-alerta-para-os-riscos\",\"link\":\"https://exame.com/ciencia/o-que-a-maconha-faz-no-cerebro-de-um-adolescente-estudo-faz-alerta-para-os-riscos/\",\"categories_data\":[{\"term_id\":3213,\"name\":\"Ciência\",\"slug\":\"ciencia\"}],\"tags_data\":[{\"term_id\":45974,\"name\":\"Maconha\",\"slug\":\"maconha\"},{\"term_id\":650719502,\"name\":\"cannabis\",\"slug\":\"cannabis\"},{\"term_id\":3007023,\"name\":\"Pesquisas científicas\",\"slug\":\"pesquisas-cientificas\"}],\"columnists_data\":false,\"exm_authors\":[{