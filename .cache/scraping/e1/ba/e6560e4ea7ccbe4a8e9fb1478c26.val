:null,\"sponsor_link\":null},\"gallery\":{\"id\":5211262,\"type\":\"exm-gallery\",\"title\":\"Acidente de avião em Washington, EUA\",\"description\":\"\",\"big_description\":\"\",\"slug\":\"acidente-de-aviao-em-washington-eua\",\"categories_data\":[{\"term_id\":772996,\"name\":\"Mundo\",\"slug\":\"mundo\"}],\"tags_data\":[{\"term_id\":68395,\"name\":\"Estados Unidos (EUA)\",\"slug\":\"estados-unidos\"},{\"term_id\":8439,\"name\":\"Washington (DC)\",\"slug\":\"washington\"},{\"term_id\":4339361,\"name\":\"acidentes-de-aviao\",\"slug\":\"acidentes-de-aviao\"}],\"cover\":{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WK4HV.jpg\",\"width\":7730,\"height\":5153,\"alt\":\"\",\"title\":\"O Capitólio dos EUA é visto à distância enquanto um veículo policial bloqueia a entrada do Rio Potomac perto do Aeroporto Nacional Reagan após um acidente aéreo em Washington, DC, em 29 de janeiro de 2025\",\"caption\":\"O Capitólio dos EUA é visto à distância enquanto um veículo policial bloqueia a entrada do Rio Potomac perto do Aeroporto Nacional Reagan após um acidente aéreo em Washington, DC, em 29 de janeiro de 2025. Um jato regional do Kansas caiu no Rio Potomac, em Washington, após colidir no ar com um helicóptero militar perto do Aeroporto Nacional Reagan, disseram autoridades na quarta-feira, provocando uma grande resposta de emergência e aterrando todos os voos\",\"description\":\"\",\"credits\":\"ANDREW CABALLERO-REYNOLDS\",\"source\":\"AFP\"},\"gallery\":[{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WK8MB_69c604.jpg\",\"width\":7040,\"height\":4688,\"alt\":\"\",\"title\":\"Veículos de emergência e equipes de resgate são vistos nas margens do Rio Potomac depois que um avião que se aproximava do Aeroporto Nacional Reagan caiu no rio fora de Washington, DC, em 30 de janeiro de 2025\",\"caption\":\"Veículos de emergência e equipes de resgate são vistos nas margens do Rio Potomac depois que um avião que se aproximava do Aeroporto Nacional Reagan caiu no rio fora de Washington, DC, em 30 de janeiro de 2025. Um jato regional do Kansas caiu no Rio Potomac, em Washington, após colidir no ar com um helicóptero militar perto do Aeroporto Nacional Reagan, disseram autoridades em 29 de janeiro, provocando uma grande resposta de emergência e paralisando todos os voos\",\"description\":\"\",\"credits\":\"ANDREW CABALLERO-REYNOLDS \",\"source\":\"AFP\"},{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WK4HV.jpg\",\"width\":7730,\"height\":5153,\"alt\":\"\",\"title\":\"O Capitólio dos EUA é visto à distância enquanto um veículo policial bloqueia a entrada do Rio Potomac perto do Aeroporto Nacional Reagan após um acidente aéreo em Washington, DC, em 29 de janeiro de 2025\",\"caption\":\"O Capitólio dos EUA é visto à distância enquanto um veículo policial bloqueia a entrada do Rio Potomac perto do Aeroporto Nacional Reagan após um acidente aéreo em Washington, DC, em 29 de janeiro de 2025. Um jato regional do Kansas caiu no Rio Potomac, em Washington, após colidir no ar com um helicóptero militar perto do Aeroporto Nacional Reagan, disseram autoridades na quarta-feira, provocando uma grande resposta de emergência e aterrando todos os voos\",\"description\":\"\",\"credits\":\"ANDREW CABALLERO-REYNOLDS\",\"source\":\"AFP\"},{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WM6JP.jpg\",\"width\":5728,\"height\":3728,\"alt\":\"\",\"title\":\"A prefeita de DC, Muriel Bowser, fala em uma coletiva de imprensa no Aeroporto Nacional Reagan após um avião cair no Rio Potomac, nos arredores de Washington, DC, em 30 de janeiro de 2025\",\"caption\":\"A prefeita de DC, Muriel Bowser, fala em uma coletiva de imprensa no Aeroporto Nacional Reagan após um avião cair no Rio Potomac, nos arredores de Washington, DC, em 30 de janeiro de 2025. Um jato regional do Kansas caiu no Rio Potomac, em Washington, após colidir no ar com um helicóptero militar perto do Aeroporto Nacional Reagan, disseram autoridades em 29 de janeiro, o que levou a uma grande resposta de emergência e proibiu todos os voos. (Foto de Ting Shen / AFP)\",\"description\":\"\",\"credits\":\"Ting Shen\",\"source\":\"AFP\"},{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WK4HE.jpg\",\"width\":3405,\"height\":2270,\"alt\":\"\",\"title\":\"Luzes de veículos de emergência são vistas no Aeroporto Nacional Reagan em Washington, DC, após um acidente aéreo perto do Rio Potomac em 29 de janeiro de 2025\",\"caption\":\"Luzes de veículos de emergência são vistas no Aeroporto Nacional Reagan em Washington, DC, após um acidente aéreo perto do Rio Potomac em 29 de janeiro de 2025. Várias equipes estavam respondendo na quarta-feira após um \\\"aparente acidente aéreo\\\" no Rio Potomac em Washington, com o Aeroporto Nacional Reagan relatando pistas fechadas devido a uma emergência em andamento\",\"description\":\"\",\"credits\":\"Ting Shen\",\"source\":\"AFP\"},{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WM6JL.jpg\",\"width\":6958,\"height\":4554,\"alt\":\"\",\"title\":\"O senador dos EUA (R-KS) Roger Marshall fala em uma entrevista coletiva no Aeroporto Nacional Reagan após um avião cair no Rio Potomac, nos arredores de Washington, DC, em 30 de janeiro de 2025\",\"caption\":\"O senador dos EUA (R-KS) Roger Marshall fala em uma entrevista coletiva no Aeroporto Nacional Reagan após um avião cair no Rio Potomac, nos arredores de Washington, DC, em 30 de janeiro de 2025. Um jato regional do Kansas caiu no Rio Potomac, em Washington, após colidir no ar com um helicóptero militar perto do Aeroporto Nacional Reagan, disseram autoridades em 29 de janeiro, provocando uma grande resposta de emergência e aterrando todos os voos. (Foto de Ting Shen / AFP)\",\"description\":\"\",\"credits\":\"Ting Shen \",\"source\":\"AFP\"},{\"url\":\"https://classic.exame.com/wp-content/uploads/2025/01/000_36WK4HY.jpg\",\"width\":4539,\"height\":3028,\"alt\":\"\",\"title\":\"Um 