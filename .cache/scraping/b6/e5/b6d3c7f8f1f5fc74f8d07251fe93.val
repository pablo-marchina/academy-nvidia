7fc5d8/69e0cfd6e92d0301fac5fa30_b0abfdcff98db3942f3a7bbe43af5d36_banner-hub1x-p-500.webp 500w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69e0cfd6e92d0301fac5fa30_b0abfdcff98db3942f3a7bbe43af5d36_banner-hub1x-p-800.webp 800w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69e0cfd6e92d0301fac5fa30_b0abfdcff98db3942f3a7bbe43af5d36_banner-hub1x.webp 1001w" alt="Texto &#x27;Nova Parceria&#x27; acima dos logos das marcas Distrito e Lovable com fundo em degrade azul, rosa e preto."/></div></div></div></div><div class="slide-cta w-slide"><div class="cta"><div class="marquee-content"><div class="features-marquee-text-wrap"><div class="heading-3 t-tulo-cta">Parceria Distrito + Lovable</div><div class="texto-corrido-16">Distrito une sua expertise em formação de profissionais com a plataforma de vibe coding Lovable para capacitar profissionais em inteligência artificial.<br/></div><a data-w-id="bed1ac2d-df0f-5994-7178-d09570cdde03" href="https://www.distrito.me/blog/parceria-lovable-distrito-vibe-coding?utm_source=site-distrito&amp;utm_medium=banner&amp;utm_campaign=&amp;utm_term=&amp;utm_content=home-banner-carrossel" target="_blank" class="button black w-inline-block"><div class="button-primary-content"><div class="button-text-color"><div class="text-size-medium text-weight-medium">Saiba mais</div></div></div><div class="button-fill white"></div></a></div></div><div class="integrations-marquee-wrapper"><div class="cta-image"><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/693182dab40d408216b79620_992c50b2766a15bf8f7266613e3973cd_banner_lovable.webp" loading="lazy" sizes="100vw" srcset="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/693182dab40d408216b79620_992c50b2766a15bf8f7266613e3973cd_banner_lovable-p-500.webp 500w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/693182dab40d408216b79620_992c50b2766a15bf8f7266613e3973cd_banner_lovable-p-800.webp 800w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/693182dab40d408216b79620_992c50b2766a15bf8f7266613e3973cd_banner_lovable-p-1080.webp 1080w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/693182dab40d408216b79620_992c50b2766a15bf8f7266613e3973cd_banner_lovable.webp 1334w" alt="Texto &#x27;Nova Parceria&#x27; acima dos logos das marcas Distrito e Lovable com fundo em degrade azul, rosa e preto."/></div></div></div></div><div class="slide-cta w-slide"><div class="cta"><div class="marquee-content"><div class="features-marquee-text-wrap"><div class="heading-3 t-tulo-cta">Distrito AI Adoption Framework</div><div class="texto-corrido-16">Mapeie dores, identifique oportunidades e estruture a governança da sua operação com nosso framework proprietário. Conheça as 6 etapas para aplicar IA com eficiência e reduzir riscos.<br/></div><a data-w-id="ed81c142-c405-e951-8bdd-7516e3b8fc31" href="https://ai-framework.distrito.me?utm_source=site-distrito&amp;utm_medium=banner&amp;utm_campaign=&amp;utm_term=&amp;utm_content=home-banner-carrossel" target="_blank" class="button black w-inline-block"><div class="button-primary-content"><div class="button-text-color"><div class="text-size-medium text-weight-medium">Saiba mais</div></div></div><div class="button-fill white"></div></a></div></div><div class="integrations-marquee-wrapper"><div class="cta-image"><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69174dc54bb26292667750c9_04fde0631ad2f827abc7edefa6fa13e1_framework.webp" loading="lazy" sizes="100vw" srcset="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69174dc54bb26292667750c9_04fde0631ad2f827abc7edefa6fa13e1_framework-p-500.webp 500w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69174dc54bb26292667750c9_04fde0631ad2f827abc7edefa6fa13e1_framework-p-800.webp 800w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69174dc54bb26292667750c9_04fde0631ad2f827abc7edefa6fa13e1_framework.webp 1356w" alt="Infográfico em português detalhando a matriz de complexidade e priorização de soluções de IA, com gráficos, diagramas de Venn e etapas de desenvolvimento e governança."/></div></div></div></div><div class="slide-cta w-slide"><div class="cta"><div class="marquee-content"><div class="features-marquee-text-wrap"><div class="heading-3 t-tulo-cta">Diagnóstico de Maturidade em IA</div><div class="texto-corrido-16">Avalie a maturidade da sua organização no uso de Inteligência Artificial com o método AI Transformation Index (ATI). Identifique o seu estágio atual e defina estratégias claras para acelerar suas operações.<br/></div><a data-w-id="f92e76b2-c914-5dd7-5341-ffedf9bb1d19" href="https://diagnostico-ia.distrito.me?utm_source=site-distrito&amp;utm_medium=banner&amp;utm_campaign=&amp;utm_term=&amp;utm_content=home-banner-carrossel" target="_blank" class="button black w-inline-block"><div class="button-primary-content"><div class="button-text-color"><div class="text-size-medium text-weight-medium">Saiba mais</div></div></div><div class="button-fill white"></div></a></div></div><div class="integrations-marquee-wrapper"><div class="cta-image"><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/68f62fb440063f9bb0093156_dbd268d2ca306238d94fc84569c38a46_diagnostico-ia%20%282%29.webp" loading="lazy" sizes="100vw" srcset="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/68f62fb440063f9bb0093156_dbd268d2ca306238d94fc84569c38a46_diagnostico-ia%20%282%29-p-500.webp 500w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/68f62fb440063f9bb0093156_dbd268d2ca306238d94fc84569c38a46_diagnostico-ia%20%282%29-p-800.webp 800w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/68f62fb440063f9bb0093156_dbd268d2ca306238d94fc84569c38a46_diagnostico-ia%20%282%29-p-1080.webp 1080w, https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/68f62fb440063f9bb0093156_dbd268d2ca306238d94fc84569c38a46_diagnostico-ia%20%282%29.webp 1288w" alt="Pessoa usando laptop que exibe um relatório de diagnóstico de IA com gráfico radar e pontuação ATI de 78 de 100 pontos."/></div></div></div></div></div><div class="left-arrow-2 w-slider-arrow-left"><div class="icon-4 w-icon-slider-left"></div></div><div class="left-arrow-2 w-slider-arrow-right"><div class="icon-4 w-icon-slider-right"></div></div><div class="slide-nav-2 w-slider-nav w-slider-nav-invert w-round"></div></div><div class="w-layout-blockcontainer container w-container"></div></div></section><div class="page-wrapper"><footer class="footer"><div class="footer-wrapper"><div class="padding-global-footer"><div class="w-layout-blockcontainer container-copy-copy w-container"><div class="footer-component"><div class="div-block-19"><div class="colluna01"><a href="/" aria-current="page" class="link-block-4 w-inline-block w--current"><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/67cb0ee33c25aa8e5f346210_logo-distrito.svg" loading="lazy" alt="logo da empresa de inteligência artificial, distrito" class="image-55"/></a><div class="footer-social-wrap"><a href="https://www.linkedin.com/company/distrito-me" target="_blank" class="footer-social-link-copy w-inline-block"><div class="categorias-footer caps color-pink">Linkedin</div><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69160d72950ba77d4305e11d_67be0f2df498bb6c8a7fc6aa_Arrow%201.svg" loading="lazy" alt="arrow icon" class="image-70"/></a><a href="https://www.instagram.com/distrito.me/" target="_blank" class="footer-social-link-copy w-inline-block"><div class="categorias-footer caps color-pink">instagram</div><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d8/69160d72950ba77d4305e11d_67be0f2df498bb6c8a7fc6aa_Arrow%201.svg" loading="lazy" alt="arrow icon" class="image-70"/></a><a href="https://www.youtube.com/c/Distrito" target="_blank" class="footer-social-link-copy w-inline-block"><div class="categorias-footer caps color-pink">youtube</div><img src="https://cdn.prod.website-files.com/67be0f2cf498bb6c8a7fc5d