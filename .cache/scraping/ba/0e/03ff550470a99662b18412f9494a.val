    <div id="home-hero-root" data-props="{&quot;headingLead&quot;:&quot;Skip the setup.&quot;,&quot;headingEmphasis&quot;:&quot;Start building.&quot;,&quot;body&quot;:&quot;Every launchable is a working GPU environment — opinionated defaults, pinned containers, and the NVIDIA stack wired end to end. Go from `brev create` to running code in minutes.&quot;,&quot;ctaPrimary&quot;:{&quot;text&quot;:&quot;Launch an Instance&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/environment/new?utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;},&quot;ctaSecondary&quot;:{&quot;macos&quot;:&quot;brew install brevdev/homebrew-brev/brev&quot;,&quot;linux&quot;:&quot;curl -fsSL https://raw.githubusercontent.com/brevdev/brev-cli/main/bin/install-latest.sh | bash&quot;,&quot;windows&quot;:&quot;# In PowerShell (admin), then restart and reopen in Ubuntu:\nwsl --install -d Ubuntu-22.04\ncurl -fsSL https://raw.githubusercontent.com/brevdev/brev-cli/main/bin/install-latest.sh | bash&quot;},&quot;features&quot;:[{&quot;icon&quot;:&quot;check&quot;,&quot;label&quot;:&quot;One-click GPU environments&quot;},{&quot;icon&quot;:&quot;window_code&quot;,&quot;label&quot;:&quot;Open-source notebooks&quot;},{&quot;icon&quot;:&quot;software_stack&quot;,&quot;label&quot;:&quot;Create and share your own Launchable&quot;}],&quot;tiles&quot;:[{&quot;id&quot;:&quot;home-hero-tile-1&quot;,&quot;title&quot;:&quot;NemoClaw&quot;,&quot;description&quot;:&quot;Use NemoClaw through OpenClaw to drive OpenShell-backed sandbox workflows. With OpenShell runtime and part of the NVIDIA Agent Toolkit, it provides additional security for running autonomous agents.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-3Azt0aYgVNFEuz7opyx3gscmowS\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;image&quot;,&quot;background_image&quot;:&quot;https://developer.nvidia.com/assets/home/claws-3264b0d9bee811a614a32e1740faae0a470f8531fd9992d6af7c8f3ddc5fe23d.png&quot;,&quot;background_color&quot;:&quot;#000000&quot;,&quot;background_size&quot;:&quot;contain&quot;,&quot;background_position&quot;:&quot;right center&quot;,&quot;corner_tag&quot;:&quot;Featured&quot;,&quot;corner_tag_color&quot;:&quot;green&quot;,&quot;tags&quot;:[&quot;OpenShell&quot;,&quot;Nemotron&quot;,&quot;Agent&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;},{&quot;id&quot;:&quot;home-hero-tile-2&quot;,&quot;title&quot;:&quot;Hermes Agent&quot;,&quot;description&quot;:&quot;Deploy Hermes, the self-improving AI agent from Nous Research, on a Brev CPU-backed VM with a secure browser dashboard and first-run provider setup for NVIDIA NIM, OpenAI, Anthropic, and Gemini.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-3EJslHqi8ugW91RBgD3erRCQEJ7\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;image&quot;,&quot;background_image&quot;:&quot;https://developer.nvidia.com/assets/home/hermes-agent-nous-logo-ab3c501772ebe3a98a0a7b2f72dd9918ab0b2fff5a9c189c8bd79cad72005439.png&quot;,&quot;background_color&quot;:&quot;#000000&quot;,&quot;background_size&quot;:&quot;contain&quot;,&quot;background_position&quot;:&quot;center&quot;,&quot;corner_tag&quot;:&quot;Agent&quot;,&quot;corner_tag_color&quot;:&quot;green&quot;,&quot;tags&quot;:[&quot;Agent&quot;,&quot;NIM&quot;,&quot;Nous Research&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;},{&quot;id&quot;:&quot;home-hero-tile-3&quot;,&quot;title&quot;:&quot;Isaac Sim Lab&quot;,&quot;description&quot;:&quot;Try the simplified approach to using Isaac Lab and Isaac Sim in the cloud, without local installation.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-35JP2ywERLgqtD0b0MIeK1HnF46\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;image&quot;,&quot;background_image&quot;:&quot;https://developer.nvidia.com/assets/home/isaac-821440f2845d5ae05bf266e0d0a53f6042df025a6cad5ca18f09a5362301f909.jpg&quot;,&quot;background_color&quot;:null,&quot;background_size&quot;:&quot;cover&quot;,&quot;background_position&quot;:&quot;center&quot;,&quot;corner_tag&quot;:&quot;Robotics&quot;,&quot;corner_tag_color&quot;:&quot;purple&quot;,&quot;tags&quot;:[&quot;Isaac&quot;,&quot;Omniverse&quot;,&quot;Robotics&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;},{&quot;id&quot;:&quot;home-hero-tile-4&quot;,&quot;title&quot;:&quot;Build an Agent&quot;,&quot;description&quot;:&quot;You can learn how to create AI agents that can perform complex tasks using Large Language Models (LLMs) and tools using the Build an Agent launchable.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-32kC34ErT9wsqTcJyaKMxBEuhr2\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;teal&quot;,&quot;background_image&quot;:null,&quot;background_color&quot;:null,&quot;background_size&quot;:null,&quot;background_position&quot;:null,&quot;corner_tag&quot;:&quot;Workshop&quot;,&quot;corner_tag_color&quot;:&quot;blue&quot;,&quot;tags&quot;:[&quot;Agent&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;},{&quot;id&quot;:&quot;home-hero-tile-5&quot;,&quot;title&quot;:&quot;Video Data Augmentation for Physical AI&quot;,&quot;description&quot;:&quot;Turn real or simulated RGB video into diverse, model-ready physical AI datasets using agent skills to curate, augment, auto-label, and generate training data in one unified workflow.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-3DH5QPdLRWBABdW9Lxn4vQBK5mW\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;black&quot;,&quot;background_image&quot;:null,&quot;background_color&quot;:null,&quot;background_size&quot;:null,&quot;background_position&quot;:null,&quot;corner_tag&quot;:&quot;Physical AI&quot;,&quot;corner_tag_color&quot;:&quot;purple&quot;,&quot;tags&quot;:[&quot;Physical AI&quot;,&quot;Robotics&quot;,&quot;Dataset&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;},{&quot;id&quot;:&quot;home-hero-tile-6&quot;,&quot;title&quot;:&quot;Video Search and Summarization&quot;,&quot;description&quot;:&quot;Build vision agents capable of ingesting massive volumes of live or archived videos and extract insights for summarization and interactive Q\u0026A.&quot;,&quot;url&quot;:&quot;https://brev.nvidia.com/launchable/deploy?launchableID=env-2tYIjRXL4eMCbH9Az8mJC5WPAI4\u0026utm_source=developer\u0026utm_medium=referral\u0026utm_campaign=home_hero&quot;,&quot;background_kind&quot;:&quot;image&quot;,&quot;background_image&quot;:&quot;https://developer.nvidia.com/assets/home/vss-high-level-arch-b0a448303d660cb5f32a7f450a8627df625835dcdeafa675458c865b657198d0.png&quot;,&quot;background_color&quot;:null,&quot;background_size&quot;:&quot;cover&quot;,&quot;background_position&quot;:&quot;center&quot;,&quot;corner_tag&quot;:&quot;Blueprint&quot;,&quot;corner_tag_color&quot;:&quot;blue&quot;,&quot;tags&quot;:[&quot;Vision AI&quot;,&quot;Video&quot;,&quot;Blueprint&quot;],&quot;footer_tags&quot;:[],&quot;cta_text&quot;:&quot;Launch&quot;}]}"></div>
