<script>
  jQuery(document).ready(function(){
    
     $sliderDepowidget_1762195850263 = jQuery('#carrossel-widget_1762195850263');
     var $wrap   = $('#widget_1762195850263.carrosel_depoimentos');
      var $prev   = $wrap.find('.prev-slide');
      var $next   = $wrap.find('.next-slide');
    
     $prev.on('click', function (e) {
        e.preventDefault();
        $sliderDepowidget_1762195850263.slick('slickPrev');
      });
      $next.on('click', function (e) {
        e.preventDefault();
        $sliderDepowidget_1762195850263.slick('slickNext');
      });
  
  $sliderDepowidget_1762195850263.slick({
    slidesToShow: 1,
    slidesToScroll: 1,
    speed: 400,
    variableWidth: false,
    infinite: false,
    arrows:false,
    responsive: [{
        breakpoint: 768,
        settings: {
            slidesToShow: 1,
          }
        },
        {
        breakpoint: 1024,
        settings: {
            slidesToShow: 1,
          }
        },
        {
        breakpoint: 1330,
        settings: {
            slidesToShow: 1,
          }
        }]
        
  });
    function updateArrowsStatewidget_1762195850263(currentIndex) {
        var slick = $sliderDepowidget_1762195850263.slick('getSlick'); // objeto interno do slick
        var total = slick.slideCount;
        var show  = slick.options.slidesToShow;

        // Está no primeiro "página"?
        var atStart = currentIndex <= 0;
        // Está na última "página" (considerando slidesToShow)?
        var maxIndex = Math.max(0, total - show);
        var atEnd = currentIndex >= maxIndex;

        $prev.toggleClass('is-disabled', atStart)
             .attr('aria-disabled', atStart);
        $next.toggleClass('is-disabled', atEnd)
             .attr('aria-disabled', atEnd);
      }

      // Atualiza ao iniciar e a cada troca de slide
      $sliderDepowidget_1762195850263.on('init', function (e, slick) {
        updateArrowsStatewidget_1762195850263(slick.currentSlide || 0);
      });
      $sliderDepowidget_1762195850263.on('afterChange', function (e, slick, current) {
        updateArrowsStatewidget_1762195850263(current);
      });

      // Se o init já aconteceu antes do bind (edge cases), força update
      if ($sliderDepowidget_1762195850263.hasClass('slick-initialized')) {
        var s = $sliderDepowidget_1762195850263.slick('getSlick');
        updateArrowsStatewidget_1762195850263(s.currentSlide || 0);
      }
    
});
</script>


