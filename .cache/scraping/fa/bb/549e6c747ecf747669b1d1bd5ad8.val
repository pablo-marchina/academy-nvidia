<style>
#cards_expansao_lateral.desktop {
  display: flex;
  width: 100%;
  overflow: hidden;
  border-radius: 0px;
}

#cards_expansao_lateral.desktop .card {
  position: relative;
  flex: 1;
  height: 592px;
  background-size: cover;
  background-position: center;
  transition: flex 0.5s ease, filter 0.4s ease;
  cursor: pointer;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  color: #fff;
}

#cards_expansao_lateral.desktop .card:not(.ativo) {
  filter: brightness(1);
}

#cards_expansao_lateral.desktop .card::after {
  content: "";
  position: absolute;
  inset: 0;
  /*background: linear-gradient(215deg, rgba(0, 0, 0, 0.49) 35.48%, rgba(0, 0, 0, 0.70) 59.34%);*/
  z-index: 0;
  transition: opacity 0.4s ease;
}

#cards_expansao_lateral.desktop .card .conteudo {
  position: relative;
  z-index: 1;
  padding: 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
}

/* quando expandido */
#cards_expansao_lateral.desktop .card.ativo {
  flex: 3;
  filter: brightness(1);
}

  #cards_expansao_lateral.desktop .card.ativo::after
  {
  background:linear-gradient(217deg, rgba(0, 0, 0, 0.00) 43.99%, rgba(0, 0, 0, 0.50) 75.66%);
  }  
  
#cards_expansao_lateral.desktop .card h2 {
  color: #FFF;
  font-family: "Itau Display Pro";
  font-size: 23px;
  font-style: normal;
  font-weight: 300;
  line-height: 120%;
  transition:0.4s all;
  margin:0;
  max-width:128px;
}
  
  #cards_expansao_lateral.desktop .card.ativo h2
  {
    color: #FFF;
    font-family: "Itau Display Pro";
    font-size: 28px;
    font-style: normal;
    font-weight: 300;
    line-height: 110%;
    margin-bottom:24px;
    max-width:100%;
  }

  
  #cards_expansao_lateral.desktop .card p
  {
    color: #FFF;
    font-family: "Itau Display Pro";
    font-size: 20px;
    font-style: normal;
    font-weight: 300;
    line-height: 120%;
    margin:0;
    margin-bottom:26px;
  }
/* conteúdo expandido */
#cards_expansao_lateral.desktop .card .expandido {
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transition: opacity 0.5s ease, max-height 0.5s ease;
}

#cards_expansao_lateral.desktop .card.ativo .expandido {
  opacity: 1;
  max-height: 500px;
}

#cards_expansao_lateral.desktop .card ul {
  margin: 0;
  margin-bottom:40px;
  padding: 0;
  list-style: none;
}

#cards_expansao_lateral.desktop .card ul li {
  position: relative;
  padding-left: 22px;
  margin-bottom: 6px;
  padding-left:29px;
  background: url(https://cubo.itau/hubfs/detalhe-lista.png) left top no-repeat;
  margin-bottom:20px;
  color: #FFF;
  font-family: "Itau Display Pro";
  font-size: 18px;
  font-style: normal;
  font-weight: 300;
  line-height: 120%; /* 21.6px */
  padding-top:2px;
}

  #cards_expansao_lateral.desktop .card ul li:last-child
  {
  margin-bottom:0px;
  }

#cards_expansao_lateral.desktop .btn {
  display: inline-block;
  background: #4c6fff;
  color: #fff;
  padding: 10px 18px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 600;
  margin-top: 10px;
}

#cards_expansao_lateral.desktop .btn:hover {
  background: #6c87ff;
}
  
  
#cards_expansao_lateral.desktop .btn
  {
    display:flex;
    gap:8px;
    align-items:center;
    width:  max-content;
    color: #FFFFFF!important;
    text-decoration: none;
    font-size: 18px;
    background-color: #4261FF;
    transition:0.3s all;
    font-weight:300;
    border-radius: 12px;
    padding:9px 20px 12px 20px; 
  }
  
  #cards_expansao_lateral.desktop .btn span
  {
    position:relative;
    top:2px;
  }
  
  #cards_expansao_lateral.desktop .btn img
  {
    position:relative;
    top:0;
    transition:0.3s all;
  }
  
  #cards_expansao_lateral.desktop .btn:hover
  {
    background-color:#FF50D6;
  }
  
  #cards_expansao_lateral.desktop .btn:hover img
  {
    top:-3px;
  }
  #cards_expansao_lateral.mobile, #controle_cards_expansao_lateral{display:none;}
/* responsivo */
@media (max-width: 900px) {
  #cards_expansao_lateral.desktop{display:none;}
  #cards_expansao_lateral.mobile, #controle_cards_expansao_lateral{display:block;}
  #cards_expansao_lateral_slider-mobile{
    display: flex;
    flex-direction: column;
    gap: 30px;
    width: 100%;
    overflow-x: hidden;
    overflow-y: hidden;
    align-items: flex-end;
  }
  #controle_cards_expansao_lateral.setas{
    display: flex;
    flex-direction: row;
    gap: 8px;
    justify-content: flex-end;
    width:100%;
  }
  #cards_expansao_lateral.mobile {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scroll-padding-right: 30px;
  cursor: grab;
  gap: 24px;
  padding-left: max(0px, calc((100% - 1380px)/2));
  width: 100%;
}
#cards_expansao_lateral.mobile.active {
  cursor: grabbing;
  user-select: none;
}

  #cards_expansao_lateral.mobile .card
  {
    max-width:366px;
    flex: 0 0 100%;
  }
  #cards_expansao_lateral.mobile .card .img
  {
    background-position:center;
    background-size:cover;
    width:100%;
    height:184px;
  }
  #cards_expansao_lateral.mobile .card .conteudo
  {
    background:#000;
    padding:32px 32px 32px 24px;
    margin-top:-2px;
  }
  
  #cards_expansao_lateral.mobile .card h2 
  {
