<!-- HubSpot performance collection script -->
<script defer src="/hs/hsstatic/content-cwv-embed/static-1.1293/embed.js"></script>
<script>
var hsVars = hsVars || {}; hsVars['language'] = 'pt-br';
</script>

<script src="/hs/hsstatic/cos-i18n/static-1.53/bundles/project.js"></script>

<script>
(function() {
  function animateCounter(el, duration) {
    var target = parseFloat(el.getAttribute('data-target'));
    if (isNaN(target)) return;
    
    var start = 0;
    var startTime = null;
    
    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      
      var current = start + (target - start) * progress;
      
      // Se for inteiro, arredonda; se tiver casas decimais, você pode adaptar aqui
      var displayValue = Math.floor(current);
      
      // Formatação com separador de milhar em pt-BR
      el.textContent = displayValue.toLocaleString('pt-BR');
      
      if (progress < 1) {
        window.requestAnimationFrame(step);
      } else {
        el.textContent = target.toLocaleString('pt-BR');
      }
    }
    
    window.requestAnimationFrame(step);
  }

  function initCounters() {
    var counters = document.querySelectorAll('#prova_social_numeros .numero[data-target]');
    if (!counters.length) return;
    
    // Usa IntersectionObserver para animar só quando entra na tela
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries, obs) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            animateCounter(entry.target, 1500); // 1.5s
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      
      counters.forEach(function(counter) {
        observer.observe(counter);
      });
    } else {
      // Fallback: anima tudo logo de cara
      counters.forEach(function(counter) {
        animateCounter(counter, 1500);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCounters);
  } else {
    initCounters();
  }
})();
</script>


<script>
document.addEventListener('DOMContentLoaded', function () {
  const cards = document.querySelectorAll('#cards_expansao_lateral.desktop .card');

  function ativarCard(cardAtivo) {
    cards.forEach(c => {
      c.classList.remove('ativo');
      c.setAttribute('aria-expanded', 'false');
    });
    cardAtivo.classList.add('ativo');
    cardAtivo.setAttribute('aria-expanded', 'true');
  }

  cards.forEach(card => {
    // continua funcionando no clique
    card.addEventListener('click', function () {
      ativarCard(card);
    });

    // agora também no hover (mouse em cima)
    card.addEventListener('mouseenter', function () {
      ativarCard(card);
    });
  });
});

// mobile (deixa exatamente como já está no seu código)
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('#cards_expansao_lateral_slider-mobile').forEach(setupCarousel);

  function setupCarousel(root) {
    const track = root.querySelector('#cards_expansao_lateral.mobile');
    if (!track) return;

    const btnPrev = root.querySelector('.js-prev');
    const btnNext = root.querySelector('.js-next');

    const getStep = () => {
      const card = track.querySelector('.card');
      if (!card) return 0;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || 0);
      return card.getBoundingClientRect().width + gap;
    };

    let isAnimating = false;
    let raf;
    let target = 0;

    function updateButtons() {
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (btnPrev) btnPrev.classList.toggle('disabled', track.scrollLeft <= 0);
      if (btnNext) btnNext.classList.toggle('disabled', track.scrollLeft >= maxScroll - 2);
    }

    updateButtons();

    if (btnNext) {
      btnNext.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft + getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    if (btnPrev) {
      btnPrev.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft - getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      if (isAnimating) return;
      isDown = true;
      track.classList.add('active');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      cancelAnimationFrame(raf);
    });

    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.classList.remove('active');
    });

    track.addEventListener('mouseup', () => {
      isDown = false;
      track.classList.remove('active');
      updateButtons();
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown || isAnimating) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1;
      target = scrollLeft - walk;
      smoothAnimate();
      updateButtons();
    });

    function smoothAnimate() {
      cancelAnimationFrame(raf);
      const step = () => {
        if (isAnimating) return;
        track.scrollLeft += (target - track.scrollLeft) * 0.2;
        if (Math.abs(target - track.scrollLeft) > 0.5) {
          raf = requestAnimationFrame(step);
        } else {
          updateButtons();
        }
      };
      raf = requestAnimationFrame(step);
    }

    function smoothScroll(element, to, duration, callback) {
      const start = element.scrollLeft;
      const change = to - start;
      const startTime = performance.now();

      const animateScroll = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        element.scrollLeft = start + change * easeOutQuad(progress);
        if (progress < 1) {
          requestAnimationFrame(animateScroll);
        } else if (callback) {
          callback();
        }
      };

      requestAnimationFrame(animateScroll);
    }

    function easeOutQuad(t) {
      return t * (2 - t);
    }
  }
});
</script>


<script>

//mobile
  
  document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('#quatro_cards_misto.mobile').forEach(setupCarouselQuatro);

  function setupCarouselQuatro(root) {
    const track = root.querySelector('#slide_quatro_cards_misto');
    if (!track) return;

    const btnPrev = root.querySelector('.js-prev.quatro');
    const btnNext = root.querySelector('.js-next.quatro');

    const getStep = () => {
      const card = track.querySelector('.cardmobile');
      if (!card) return 0;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || 0);
      return card.getBoundingClientRect().width + gap;
    };

    let isAnimating = false;
    let raf;
    let target = 0;

    // Atualiza visibilidade dos botões
    function updateButtons() {
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (btnPrev) btnPrev.classList.toggle('disabled', track.scrollLeft <= 0);
      if (btnNext) btnNext.classList.toggle('disabled', track.scrollLeft >= maxScroll - 2);
    }

    // Executa uma vez no início
    updateButtons();

    // Botões next/prev com animação suave
    if (btnNext) {
      btnNext.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft + getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    if (btnPrev) {
      btnPrev.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft - getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    // Arrastar com mouse
    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      if (isAnimating) return;
      isDown = true;
      track.classList.add('active');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      cancelAnimationFrame(raf);
    });

    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.classList.remove('active');
    });

    track.addEventListener('mouseup', () => {
      isDown = false;
      track.classList.remove('active');
      updateButtons(); // atualiza ao soltar
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown || isAnimating) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1;
      target = scrollLeft - walk;
      smoothAnimate();
      updateButtons();
    });

    function smoothAnimate() {
      cancelAnimationFrame(raf);
      const step = () => {
        if (isAnimating) return;
        track.scrollLeft += (target - track.scrollLeft) * 0.2;
        if (Math.abs(target - track.scrollLeft) > 0.5) {
          raf = requestAnimationFrame(step);
        } else {
          updateButtons();
        }
      };
      raf = requestAnimationFrame(step);
    }

    // Função para animação suave dos botões
    function smoothScroll(element, to, duration, callback) {
      const start = element.scrollLeft;
      const change = to - start;
      const startTime = performance.now();

      const animateScroll = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        element.scrollLeft = start + change * easeOutQuad(progress);
        if (progress < 1) {
          requestAnimationFrame(animateScroll);
        } else if (callback) {
          callback();
        }
      };

      requestAnimationFrame(animateScroll);
    }

    function easeOutQuad(t) {
      return t * (2 - t);
    }
  }
});

</script>


