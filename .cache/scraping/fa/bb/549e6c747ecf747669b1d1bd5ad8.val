<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.conteiner-carrossel').forEach(setupCarousel);

  function setupCarousel(root) {
    const track = root.querySelector('.carrossel-mobile');
    if (!track) return;

    const btnPrev = root.querySelector('.bot-quadro-prev');
    const btnNext = root.querySelector('.bot-quadro-next');

    const getStep = () => {
      const card = track.querySelector('.slide-carrossel');
      if (!card) return 0;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || 0);
      return card.getBoundingClientRect().width + gap;
    };

    let isAnimating = false;
    let raf;
    let target = 0;

    // Atualiza visibilidade dos botões
    function updateButtons() {
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (btnPrev) btnPrev.classList.toggle('disabled', track.scrollLeft <= 0);
      if (btnNext) btnNext.classList.toggle('disabled', track.scrollLeft >= maxScroll - 2);
    }

    // Executa uma vez no início
    updateButtons();

    // Botões next/prev com animação suave
    if (btnNext) {
      btnNext.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft + getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    if (btnPrev) {
      btnPrev.addEventListener('click', () => {
        if (isAnimating) return;
        isAnimating = true;
        smoothScroll(track, track.scrollLeft - getStep(), 400, () => {
          isAnimating = false;
          updateButtons();
        });
      });
    }

    // Arrastar com mouse
    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      if (isAnimating) return;
      isDown = true;
      track.classList.add('active');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      cancelAnimationFrame(raf);
    });

    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.classList.remove('active');
    });

    track.addEventListener('mouseup', () => {
      isDown = false;
      track.classList.remove('active');
      updateButtons(); // atualiza ao soltar
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown || isAnimating) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1;
      target = scrollLeft - walk;
      smoothAnimate();
      updateButtons();
    });

    function smoothAnimate() {
      cancelAnimationFrame(raf);
      const step = () => {
        if (isAnimating) return;
        track.scrollLeft += (target - track.scrollLeft) * 0.2;
        if (Math.abs(target - track.scrollLeft) > 0.5) {
          raf = requestAnimationFrame(step);
        } else {
          updateButtons();
        }
      };
      raf = requestAnimationFrame(step);
    }

    // Função para animação suave dos botões
    function smoothScroll(element, to, duration, callback) {
      const start = element.scrollLeft;
      const change = to - start;
      const startTime = performance.now();

      const animateScroll = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        element.scrollLeft = start + change * easeOutQuad(progress);
        if (progress < 1) {
          requestAnimationFrame(animateScroll);
        } else if (callback) {
          callback();
        }
      };

      requestAnimationFrame(animateScroll);
    }

    function easeOutQuad(t) {
      return t * (2 - t);
    }
  }
});
</script></div>

</div><!--end widget-span -->
</div><!--end row-->
</div><!--end row-wrapper -->

</div><!--end widget-span -->
</div><!--end row-->
</div><!--end row-wrapper -->

