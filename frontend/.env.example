# =============================================================================
# Frontend Configuration — NVIDIA Startup AI Radar Product UI
# =============================================================================
# Copy this file to frontend/.env and adjust as needed.
#   cp frontend/.env.example frontend/.env
#
# All VITE_ variables are client-side and visible in the browser bundle.
# Never put secrets (API keys, passwords) in frontend env vars.
# =============================================================================

VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
