# =============================================================================
# NVIDIA Startup AI Radar - Production Environment Template
# =============================================================================
# Copy to a secure environment-specific location and fill values before running
# product mode. Do not commit a real .env file with secrets.
# =============================================================================

# Core product runtime
APP_MODE=product
PRODUCT_DB_URL=postgresql://postgres:postgres@localhost:5432/startup_radar
ENABLE_PRODUCT_PERSISTENCE=true
PRODUCT_DATA_DIR=data/product

# Required RAG runtime
RAG_VECTOR_BACKEND=qdrant
RAG_REQUIRED_FOR_PRODUCT=true
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nvidia_corpus
QDRANT_VECTOR_SIZE=384
QDRANT_MIN_POINTS=10

# Product workflow orchestration
AGENT_ORCHESTRATION_ENABLED=true

# Retrieval quality knobs. Keep dense_only unless a direct benchmark promotes
# hybrid_with_rerank for this deployment.
RAG_RETRIEVAL_MODE=dense_only
RAG_DENSE_TOP_K=5
RAG_SPARSE_TOP_K=5
RAG_RERANK_TOP_K=3
RAG_DENSE_WEIGHT=0.5
RAG_SPARSE_WEIGHT=0.5
RERANKER_PROVIDER=none
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Optional evaluation features. The LLM judge has only the offline null provider
# implemented today, so it must not be used as semantic quality proof.
ANSWER_QUALITY_LLM_JUDGE_ENABLED=false
ANSWER_QUALITY_LLM_JUDGE_PROVIDER=null
ENABLE_INSTRUCTOR_TRIAL=false
RAGAS_EVAL_ENABLED=false

# Optional external services and secrets
OPENAI_API_KEY=
COHERE_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nvidia-startup-ai-radar

# Test-only integration database URL
PRODUCT_DB_TEST_URL=
