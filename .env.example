# =============================================================================
# NVIDIA Startup AI Radar — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required vars are marked [REQUIRED]. Optional vars have sensible defaults.
# Secrets are marked [SECRET] and are never logged or exposed in API responses.
# =============================================================================

# ---------------------------------------------------------------------------
# Core Product Configuration  [CORE]
# ---------------------------------------------------------------------------
PRODUCT_DB_URL=sqlite:///data/product/product.db   # [REQUIRED] DB URL (SQLite or PostgreSQL)
APP_MODE=product                                    # App mode: product, development
ENABLE_PRODUCT_PERSISTENCE=true                     # Enable transactional DB persistence
PRODUCT_DATA_DIR=data/product                       # Product data directory

# ---------------------------------------------------------------------------
# RAG / Vector Store  [RAG - OPTIONAL]
# ---------------------------------------------------------------------------
RAG_VECTOR_BACKEND=in_memory                        # in_memory or qdrant
RAG_REQUIRED_FOR_PRODUCT=false                      # Whether RAG is required
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Qdrant (only needed if RAG_VECTOR_BACKEND=qdrant)
QDRANT_URL=http://localhost:6333                    # [SECRET if auth enabled]
QDRANT_API_KEY=                                     # [SECRET] Optional API key
QDRANT_COLLECTION=nvidia_corpus                     # Collection name
QDRANT_VECTOR_SIZE=384                              # Vector dimension

# ---------------------------------------------------------------------------
# LLM Judge / Instructor Trial  [OPTIONAL]
# ---------------------------------------------------------------------------
ANSWER_QUALITY_LLM_JUDGE_ENABLED=false              # Enable optional LLM judge
ANSWER_QUALITY_LLM_JUDGE_PROVIDER=null              # Provider: null, instructor_trial
ENABLE_INSTRUCTOR_TRIAL=false                       # Enable Instructor parsing trial
OPENAI_API_KEY=                                     # [SECRET] For future OpenAI structured outputs

# ---------------------------------------------------------------------------
# Observability  [OPTIONAL]
# ---------------------------------------------------------------------------
LANGSMITH_API_KEY=                                  # [SECRET] LangSmith API key
LANGSMITH_PROJECT=nvidia-startup-ai-radar           # LangSmith project name

# ---------------------------------------------------------------------------
# Database Test  [TEST ONLY]
# ---------------------------------------------------------------------------
PRODUCT_DB_TEST_URL=                                # [SECRET] PostgreSQL for integration tests
